{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "DATABASE_URL",
        "DATABASE_URL_APP",
        "CLERK_SECRET_KEY",
        "PRISMCORE_ENCRYPTION_KEY",
        "CRON_SECRET",
        "ANTHROPIC_API_KEY",
        "RESEND_API_KEY",
        "STRATEGY_ALERT_FROM",
        "STRIPE_SECRET_KEY",
        "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "BLOB_READ_WRITE_TOKEN"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {}
  }
}
