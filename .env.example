# Neon Postgres — admin (BYPASSRLS) connection. Migrations & bootstrap only.
DATABASE_URL=

# Neon Postgres — app (NOBYPASSRLS) connection. All tenant-scoped runtime access.
# Falls back to DATABASE_URL if unset (do NOT do this in production).
DATABASE_URL_APP=

# Clerk auth — provisioned via the Vercel Marketplace (vercel integration add clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Point Clerk's protect-redirect at the app's own sign-in / sign-up pages.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
